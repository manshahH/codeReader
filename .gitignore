.env
.env.*
!.env.example
# D-114: holds no secret (VITE_API_BASE_URL is deliberately empty, so the SPA
# calls the API same-origin through the vercel.json rewrite). Must be tracked --
# Vercel builds from git, and an untracked file means the production build
# silently falls back to http://localhost:8000.
!frontend/.env.production
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/
dist/
build/
*.egg-info/
node_modules/
frontend/dist/
frontend/dev-dist/
frontend/.vite/
frontend/playwright-report/
frontend/test-results/
frontend/e2e/.auth/
frontend/.e2e-token.env
frontend/.lh-token.txt
frontend/lighthouse-*.report.*
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
coverage/
.coverage
htmlcov/
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
docker-compose.override.yml
pipeline/validation_reports/
data/events/
backend/data/
frontend/.env.local
# Full pg_dump output (users, exercises, attempts). A stray `git add .` would
# put real user data into git history permanently, where deleting it later does
# not remove it. Never track this.
.backups/
# One-off frontend verification artifacts (screenshots + throwaway scripts).
frontend/_final-*
# D-129 viewer visual/DOM harness output (evidence, not source)
frontend/viewer-shots/
frontend/viewer-dom/
frontend/narrow-audit/
