# D-112: paste a managed provider's connection URL here verbatim. A libpq URL
# (Neon/Supabase/RDS style, ?sslmode=require&channel_binding=require) is
# normalized in app/db.py: the +asyncpg driver is forced, sslmode is translated,
# params asyncpg cannot accept are dropped and logged, and a transaction pooler
# host (-pooler/.pooler/pgbouncer) turns off prepared statement caching. Do NOT
# hand-convert the string; the app and the healthz probe want opposite forms of
# it and no single hand-written value satisfies both.
# A remote host with no sslmode defaults to verified TLS (verify-full).
DATABASE_URL=postgresql://codereader:codereader@localhost:5432/codereader
# rediss:// (Upstash and other managed TLS Redis) works as-is: redis.asyncio
# maps the scheme to SSLConnection itself. Note Upstash has no SELECT, so no /N.
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-current-secret,replace-with-previous-secret
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_DAYS=60
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
TOKEN_ENC_KEY=replace-with-32-byte-token-encryption-key
APP_ORIGIN=http://localhost:5173
ANTHROPIC_API_KEY=
OPENAI_API_KEY=replace-with-openai-api-key
GENERATOR_PROVIDER=openai
VALIDATION_REPORTS_DIR=pipeline/validation_reports
GATE_PROVIDER=openai
# D-81 (pipeline defect #5): the semantic gate judges execution-verified
# content, so a weak judge that miscounts line numbers or lists hypothetical
# "defects" false-rejects good exercises. gpt-4o-mini was too weak on both.
# Recommended: gpt-4o -- clearly stronger at instruction-following (obeys the
# "not a defect" list) AND, being a gpt-4* family, it still honors the gates'
# designed temperature=0 (a deterministic, reproducible judge). A gpt-5* model
# is smarter still but CANNOT honor a non-default temperature (D-55), so the
# judge would run non-deterministically -- only pick one if you accept that.
# Must differ from GENERATOR_MODEL (D-14).
GATE_MODEL=gpt-4o
GENERATOR_MODEL=gpt-4.1
# D-80: optional per-type generator override for spot_the_bug ONLY (the
# flagship). Empty = use GENERATOR_MODEL for STB too (the default; routing OFF).
# Set to a stronger model to route only STB generation there; must differ from
# GATE_MODEL (D-14). trace and the predict_the_fix distractor step stay on
# GENERATOR_MODEL.
GENERATOR_MODEL_STB=
# D-83 feedback-driven repair + D-84 best-of-N selection. Both ON for the real
# batch (a REPAIRABLE gate rejection is fed back for a targeted fix instead of
# regenerated blind; a spec may produce several survivors and publish the best).
# MAX_ATTEMPTS_PER_SPEC caps TOTAL generation calls per spec (fresh + repair).
REPAIR_ENABLED=true
BEST_OF_N_ENABLED=true
MAX_ATTEMPTS_PER_SPEC=4
MAX_REPAIR_ROUNDS=2
BEST_OF_N_MAX_SURVIVORS=2
BEST_OF_N_SCORE_THRESHOLD=0.70
BEST_OF_N_COVERAGE_THRESHOLD=2
GRADER_PROVIDER=openai
GRADER_MODEL=replace-with-grader-model
GRADER_TIMEOUT_S=6
SANDBOX_HOST=
S3_BUCKET=replace-with-events-bucket
S3_EVENTS_PREFIX=events/
EVENTS_LOCAL_DIR=data/events
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_ATTEMPTS_PER_MINUTE=10
RATE_LIMIT_AUTH_PER_MINUTE=10
TRUSTED_PROXY_COUNT=1
ADMIN_METRICS_TOKEN=replace-with-admin-metrics-token
BETA_GATE_ENABLED=false
# A1 streak safety net (docs/10; D-116)
STREAK_FREEZE_START=2
STREAK_FREEZE_MAX=2
STREAK_FREEZE_EARN_EVERY=10
STREAK_REPAIR_WINDOW_H=48
# A2 email capture (docs/10; D-120). EMAIL_SENDING_ENABLED is a hard off-switch
# and stays false everywhere except production: false means the Resend client
# short-circuits before building a request, so no local run or test can send.
# RESEND_API_KEY is optional here and validated lazily at first send (D-44
# pattern), so an empty value never blocks constructing Settings.
EMAIL_SENDING_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=CodeReader <no-reply@codereader.dev>
EMAIL_VERIFICATION_TTL_H=24
EMAIL_VERIFICATION_RESEND_COOLDOWN_S=60
EMAIL_VERIFICATION_SENDS_PER_HOUR=5
# A3 reminders + weekly recap (docs/10; D-137). None of this can send while
# EMAIL_SENDING_ENABLED above is false; the jobs use the same off-switch.
# Retries are bounded by a count AND a 24h window, because the second
# send-once layer is Resend's Idempotency-Key and it only holds for 24h.
EMAIL_SEND_MAX_ATTEMPTS=3
EMAIL_SEND_RETRY_WINDOW_H=24
# Sequential and paced, never a concurrent fan-out (2/s is Resend's default
# rate limit). The per-tick cap defers rather than drops.
EMAIL_JOB_BATCH_SIZE=200
EMAIL_MAX_SENDS_PER_TICK=100
EMAIL_SENDS_PER_SECOND=2.0
# The recap reports the ISO week that just ended, so Monday (0) is the first
# moment it is complete. The hour is fixed, not the user's reminder time, so
# the two emails cannot land together.
RECAP_LOCAL_WEEKDAY=0
RECAP_LOCAL_HOUR=9
JOB_REMINDERS_INTERVAL_S=300.0
JOB_WEEKLY_RECAP_INTERVAL_S=900.0
# D-123: summarize is OFF (D-115). false means a live summarize row can never
# be sampled into a session. Turning it on re-enables the only type with a
# per-answer LLM cost and a grader on the hot path.
SUMMARIZE_ENABLED=false
JOBS_ENABLED=true
JOB_GRADING_RETRY_INTERVAL_S=30
JOB_PERCENTILES_INTERVAL_S=3600
JOB_PARTITIONS_INTERVAL_S=86400
CODEREADER_ALLOW_SEED=false
